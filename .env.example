# === Neo4j Graph Database ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# === LLM Configuration (OpenRouter) ===
OPENROUTER_API_KEY=your_openrouter_api_key
